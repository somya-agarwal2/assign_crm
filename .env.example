# Flask Application Environment
FLASK_ENV=development
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database Settings
# For local development: sqlite:///app.db
# For production (Neon PostgreSQL):
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require&channel_binding=require
GEMINI_API_KEY=your_google_gemini_api_key_here
GROK_API_KEY=your_xai_grok_api_key_here
